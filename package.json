{
  "name": "picoflash-electron",
  "version": "0.1.1",
  "description": "Electron desktop wrapper for pico⚡flash",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "org.picoflash.desktop",
    "productName": "picoflash",
    "files": [
      "electron/**/*",
      "index.html",
      "style.css",
      "js/**/*",
      "pkg/**/*",
      "html/**/*",
      "images/**/*",
      "favicon.ico",
      "LICENSE",
      "README.md",
      "API.md",
      "CHANGELOG.md"
    ],
    "win": {
      "target": "nsis"
    }
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  }
}
